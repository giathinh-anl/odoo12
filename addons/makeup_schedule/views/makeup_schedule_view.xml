<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="makeup_schedule_form" model="ir.ui.view">
        <field name="name">makeup.schedule.form</field>
        <field name="model">makeup.schedule</field>
        <field name="arch" type="xml">
            <form string="Lịch Học Bù">
                <header>
                    <button name="action_xep_lich"
                        string="Xếp lịch bù"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'chua_xep'"/>

                    <button name="action_hoan_thanh"
                        string="Đã học bù xong"
                        type="object"
                        class="btn-success"
                        invisible="state != 'da_xep'"/>

                    <button name="action_open_student_contact"
                        string="Mở liên hệ"
                        type="object"
                        class="btn-secondary"
                        invisible="not student_id"/>

                    <button name="action_huy"
                        string="Huỷ"
                        type="object"
                        class="btn-danger"
                        invisible="state in ['hoan_thanh', 'huy']"/>

                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="chua_xep,da_xep,hoan_thanh,huy"/>
                </header>

                <sheet>
                    <group>
                        <group string="Thông tin học sinh">
                            <field name="student_id"
                                string="Học sinh"
                                placeholder="Tìm học sinh đã có trong Liên hệ"
                                domain="[]"
                                context="{'show_address': 1, 'show_email': 1, 'create': False}"
                                can_create="false"
                                can_write="false"
                                options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_open': False}"/>

                            <field name="student_phone" readonly="1"/>
                            <field name="student_email" readonly="1"/>
                            <field name="student_tags" widget="many2many_tags" readonly="1"/>

                            <field name="class_name"
                                string="Lớp"
                                placeholder="Tự lấy từ tag Lớp nếu có"/>

                            <field name="subject" string="Môn học"/>
                        </group>

                        <group string="Thông tin vắng">
                            <field name="absent_date" string="Ngày vắng"/>
                            <field name="absent_reason"
                                string="Lý do vắng"
                                placeholder="Nhập lý do vắng"/>
                            <field name="is_urgent"
                                string="Cần xếp gấp"
                                widget="boolean_toggle"
                                readonly="1"/>
                            <field name="days_since_absent"
                                string="Số ngày chưa bù"
                                readonly="1"/>
                        </group>
                    </group>

                    <group string="Lịch học bù">
                        <field name="makeup_date" string="Ngày học bù"/>
                        <field name="makeup_time"
                            string="Giờ học bù"
                            placeholder="VD: 14:00 - 15:30"/>
                    </group>

                    <group string="Ghi chú">
                        <field name="note"
                            nolabel="1"
                            placeholder="Nhập ghi chú nếu có..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="makeup_schedule_list" model="ir.ui.view">
        <field name="name">makeup.schedule.list</field>
        <field name="model">makeup.schedule</field>
        <field name="arch" type="xml">
            <tree string="Danh sách lịch học bù"
                decoration-danger="is_urgent == True and state == 'chua_xep'"
                decoration-warning="state == 'da_xep'"
                decoration-success="state == 'hoan_thanh'"
                decoration-muted="state == 'huy'">

                <field name="student_id" string="Học sinh"/>
                <field name="class_name" string="Lớp"/>
                <field name="subject" string="Môn học"/>
                <field name="absent_date" string="Ngày vắng"/>
                <field name="makeup_date" string="Ngày học bù"/>
                <field name="makeup_time" string="Giờ học bù"/>

                <field name="state"
                    string="Trạng thái"
                    widget="badge"
                    decoration-danger="state == 'chua_xep'"
                    decoration-warning="state == 'da_xep'"
                    decoration-success="state == 'hoan_thanh'"
                    decoration-muted="state == 'huy'"/>

                <field name="is_urgent" invisible="1"/>

                <button name="action_xep_lich"
                    type="object"
                    string="Xếp lịch"
                    class="btn-sm btn-primary"
                    invisible="state != 'chua_xep'"/>

                <button name="action_hoan_thanh"
                    type="object"
                    string="Xong"
                    class="btn-sm btn-success"
                    invisible="state != 'da_xep'"/>
            </tree>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="makeup_schedule_search" model="ir.ui.view">
        <field name="name">makeup.schedule.search</field>
        <field name="model">makeup.schedule</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm lịch học bù">
                <field name="student_id" string="Học sinh"/>
                <field name="class_name" string="Lớp"/>
                <field name="subject" string="Môn học"/>

                <separator/>

                <filter name="chua_xep"
                    string="Chưa xếp lịch"
                    domain="[('state','=','chua_xep')]"/>

                <filter name="can_gap"
                    string="Cần xếp gấp"
                    domain="[('is_urgent','=',True),('state','=','chua_xep')]"/>

                <filter name="da_xep"
                    string="Đã xếp lịch"
                    domain="[('state','=','da_xep')]"/>

                <filter name="hoan_thanh"
                    string="Đã học bù"
                    domain="[('state','=','hoan_thanh')]"/>

                <filter name="huy"
                    string="Đã huỷ"
                    domain="[('state','=','huy')]"/>

                <separator/>

                <group expand="0" string="Nhóm theo">
                    <filter name="group_student"
                        string="Học sinh"
                        context="{'group_by': 'student_id'}"/>

                    <filter name="group_class"
                        string="Lớp"
                        context="{'group_by': 'class_name'}"/>

                    <filter name="group_subject"
                        string="Môn"
                        context="{'group_by': 'subject'}"/>

                    <filter name="group_state"
                        string="Trạng thái"
                        context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="makeup_schedule_action" model="ir.actions.act_window">
        <field name="name">Lịch Học Bù</field>
        <field name="res_model">makeup.schedule</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="makeup_schedule_search"/>
        <field name="context">{'search_default_chua_xep': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có lịch học bù nào!
            </p>
            <p>Nhấn Tạo mới để thêm học sinh vắng.</p>
        </field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_makeup_root"
        name="Lịch Học Bù"
        sequence="15"/>

    <menuitem id="menu_makeup_all"
        name="Tất cả lịch bù"
        parent="menu_makeup_root"
        action="makeup_schedule_action"
        sequence="1"/>

    <menuitem id="menu_makeup_urgent"
        name="Cần xếp gấp"
        parent="menu_makeup_root"
        action="makeup_schedule_action"
        sequence="2"/>

</odoo>