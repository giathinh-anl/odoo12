<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW PAYMENT -->
    <record id="education_payment_form" model="ir.ui.view">
        <field name="name">education.payment.form</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <form string="Thanh Toán Học Phí">
                <header>
                    <button name="action_confirm"
                        string="Xác nhận"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"/>

                    <button name="action_create_invoice"
                        string="Tạo hóa đơn liên kết"
                        type="object"
                        class="btn-primary"
                        invisible="not id or invoice_id"/>

                    <button name="action_open_invoice"
                        string="Mở hóa đơn liên kết"
                        type="object"
                        class="btn-secondary"
                        invisible="not invoice_id"/>

                    <button name="action_register_payment"
                        string="Cập nhật thanh toán"
                        type="object"
                        class="btn-success"
                        invisible="state not in ['unpaid', 'partial']"/>

                    <button name="action_set_draft"
                        string="Đưa về nháp"
                        type="object"
                        invisible="state not in ['unpaid', 'partial', 'paid', 'cancel']"/>

                    <button name="action_cancel"
                        string="Huỷ"
                        type="object"
                        class="btn-danger"
                        invisible="state == 'cancel'"/>

                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="draft,unpaid,partial,paid,cancel"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Thông tin học sinh">
                            <field name="student_id"
                                string="Học sinh"
                                placeholder="Tìm học sinh đã có trong Liên hệ"
                                options="{'no_create': True, 'no_create_edit': True, 'no_open': False}"/>

                            <field name="student_phone" readonly="1"/>
                            <field name="student_email" readonly="1"/>
                            <field name="student_tags" widget="many2many_tags" readonly="1"/>
                            <field name="class_name" placeholder="Tự lấy từ tag Lớp nếu có"/>
                        </group>

                        <group string="Thông tin phiếu">
                            <field name="payment_date"/>
                            <field name="due_date"/>
                            <field name="payment_method"/>
                        </group>
                    </group>

                    <group string="Chi tiết học phí">
                        <field name="payment_line_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="product_id"
                                    string="Sản phẩm / Môn học"
                                    domain="[('sale_ok','=',True), ('name','ilike', parent.class_name or '')]"
                                    options="{'no_create': True, 'no_create_edit': True, 'no_open': False}"/>

                                <field name="name" string="Diễn giải"/>
                                <field name="quantity" string="Số lượng"/>
                                <field name="price_unit" string="Đơn giá"/>
                                <field name="subtotal" string="Thành tiền" readonly="1"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Theo dõi học phí">
                        <field name="total_amount" readonly="1"/>
                        <field name="paid_amount"/>
                        <field name="remaining_amount" readonly="1"/>
                    </group>

                    <group string="Mã QR chuyển khoản"
                        invisible="payment_method != 'bank'">
                        <group>
                            <field name="bank_code"/>
                            <field name="bank_account_no"/>
                            <field name="bank_account_name"/>
                            <field name="transfer_content" readonly="1"/>
                            <field name="qr_payment_url" readonly="1"/>
                        </group>
                        <group>
                            <field name="qr_payment_html" nolabel="1" readonly="1"/>
                        </group>
                    </group>

                    <group string="Hóa đơn liên kết">
                        <field name="invoice_id" readonly="1"/>
                        <field name="invoice_name" readonly="1"/>
                        <field name="invoice_state" readonly="1"/>
                        <field name="invoice_payment_state" readonly="1"/>
                    </group>

                    <group string="Ghi chú nội bộ">
                        <field name="note"
                            nolabel="1"
                            placeholder="Ghi chú thêm về thanh toán học phí..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW PAYMENT -->
    <record id="education_payment_tree" model="ir.ui.view">
        <field name="name">education.payment.tree</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <tree string="Danh sách thanh toán học phí"
                decoration-danger="state == 'unpaid'"
                decoration-warning="state == 'partial'"
                decoration-success="state == 'paid'"
                decoration-muted="state == 'cancel'">

                <field name="name"/>
                <field name="student_id"/>
                <field name="class_name"/>
                <field name="payment_date"/>
                <field name="due_date"/>
                <field name="total_amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="payment_method"/>
                <field name="invoice_id"/>

                <field name="state"
                    widget="badge"
                    decoration-danger="state == 'unpaid'"
                    decoration-warning="state == 'partial'"
                    decoration-success="state == 'paid'"
                    decoration-muted="state == 'cancel'"/>
            </tree>
        </field>
    </record>

    <!-- SEARCH VIEW PAYMENT -->
    <record id="education_payment_search" model="ir.ui.view">
        <field name="name">education.payment.search</field>
        <field name="model">education.payment</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm thanh toán học phí">
                <field name="name"/>
                <field name="student_id" string="Học sinh"/>
                <field name="class_name" string="Lớp"/>
                <field name="invoice_id" string="Hóa đơn"/>

                <separator/>

                <filter name="unpaid"
                    string="Chưa thanh toán"
                    domain="[('state','=','unpaid')]"/>

                <filter name="partial"
                    string="Thanh toán một phần"
                    domain="[('state','=','partial')]"/>

                <filter name="paid"
                    string="Đã thanh toán"
                    domain="[('state','=','paid')]"/>

                <filter name="has_invoice"
                    string="Đã có hóa đơn"
                    domain="[('invoice_id','!=',False)]"/>

                <filter name="no_invoice"
                    string="Chưa có hóa đơn"
                    domain="[('invoice_id','=',False)]"/>

                <separator/>

                <group expand="0" string="Nhóm theo">
                    <filter name="group_student"
                        string="Học sinh"
                        context="{'group_by': 'student_id'}"/>

                    <filter name="group_class"
                        string="Lớp"
                        context="{'group_by': 'class_name'}"/>

                    <filter name="group_method"
                        string="Phương thức"
                        context="{'group_by': 'payment_method'}"/>

                    <filter name="group_state"
                        string="Trạng thái"
                        context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION PAYMENT -->
    <record id="education_payment_action" model="ir.actions.act_window">
        <field name="name">Thanh Toán Học Phí</field>
        <field name="res_model">education.payment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="education_payment_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có phiếu thanh toán học phí nào!
            </p>
            <p>Tạo phiếu để quản lý học phí, mã QR và hóa đơn liên kết.</p>
        </field>
    </record>

    <!-- INHERIT INVOICE FORM -->
    <record id="account_move_form_inherit_education_payment" model="ir.ui.view">
        <field name="name">account.move.form.inherit.education.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="education_payment_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- MENU PAYMENT -->
    <menuitem id="menu_education_payment_root"
        name="Thanh Toán Học Phí"
        sequence="16"/>

    <menuitem id="menu_education_payment_all"
        name="Danh sách thanh toán"
        parent="menu_education_payment_root"
        action="education_payment_action"
        sequence="1"/>

</odoo>